# Optional: force one provider when multiple keys exist (anthropic | openai | gemini).
# If unset, first match wins: ANTHROPIC_API_KEY → OPENAI_API_KEY → GEMINI_API_KEY.
# AI_PROVIDER=anthropic

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default model: claude-sonnet-4-6
# VITE_ANTHROPIC_MODEL=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# VITE_OPENAI_MODEL=gpt-4o

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default: gemini-2.5-flash
# VITE_GEMINI_MODEL=

# Local: npm run dev / npm run preview (Vite proxies). Vercel production uses serverless /api/* routes — add the
# matching *API_KEY* in Vercel → Settings → Environment Variables (Production), redeploy, and optional VITE_AI_PROVIDER.
